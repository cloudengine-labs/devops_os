{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "id": null,
  "uid": "my-app-sre",
  "title": "My-App SRE Dashboard",
  "tags": [
    "sre",
    "slo",
    "my-app",
    "platform"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"my-app\"}[5m])",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"my-app\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"my-app\"}[5m])",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p99 Latency",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"my-app\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pod Restarts",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(kube_pod_container_status_restarts_total{pod=~\"my-app-.*\"}[15m]) * 60",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{pod=~\"my-app-.*\"}[5m])",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{pod=~\"my-app-.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "SLO Target (99.9%)",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "1 - (rate(http_requests_total{job=\"my-app\",status=~\"5..\"}[30d]) / rate(http_requests_total{job=\"my-app\"}[30d]))",
          "refId": "A",
          "legendFormat": "Availability"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9980000000000001
              },
              {
                "color": "green",
                "value": 0.9990000000000001
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}